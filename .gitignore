# ==========================================
# 1. Data & Local Databases
# ==========================================
# Ignores all the massive Kaggle CSV files
raw_data/

# Ignores the local object storage (Data Lake)
minio_data/

# Ignores local Postgres volumes (if they generate during docker-compose up)
postgres_oltp_data/
postgres_dw_data/

# ==========================================
# 2. Python & Virtual Environment
# ==========================================
# Ignores the entire virtual environment folder
venv/

# Ignores compiled Python cache files (like inside your dags/ folder)
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 3. dbt (Data Build Tool) Artifacts
# ==========================================
# Ignores auto-generated compiled SQL, downloaded packages, and dbt logs
dbt_ecommerce/target/
dbt_ecommerce/dbt_packages/
dbt_ecommerce/logs/

# Standard safety practice to prevent pushing credential files
profiles.yml 

# ==========================================
# 4. Pipeline Logs
# ==========================================
# Ignores the root logs folder (where your dbt.log currently sits)
logs/

# ==========================================
# 5. Environment Variables & OS Files
# ==========================================
.env
.DS_Store
.vscode/
.idea/