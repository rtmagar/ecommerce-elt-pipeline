e": "execute", "started_at": "2026-03-04T10:15:36.959320Z", "completed_at": "2026-03-04T10:15:37.018292Z"}], "thread_id": "Thread-2 (worker)", "execution_time": 0.07527780532836914, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.dbt_ecommerce.stg_products", "compiled": true, "compiled_code": "SELECT\n    product_id,\n    product_category_name,\n    product_weight_g,\n    product_length_cm,\n    product_height_cm,\n    product_width_cm\nFROM \"analytics_warehouse\".\"public\".\"raw_products\"", "relation_name": "\"analytics_warehouse\".\"public\".\"stg_products\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:36.946773Z", "completed_at": "2026-03-04T10:15:36.952460Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:36.956030Z", "completed_at": "2026-03-04T10:15:37.019025Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.0770571231842041, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.dbt_ecommerce.stg_order_reviews", "compiled": true, "compiled_code": "SELECT\n    review_id,\n    order_id,\n    review_score,\n    CAST(review_creation_date AS TIMESTAMP) AS review_creation_ts,\n    CAST(review_answer_timestamp AS TIMESTAMP) AS review_answer_ts\nFROM \"analytics_warehouse\".\"public\".\"raw_order_reviews\"", "relation_name": "\"analytics_warehouse\".\"public\".\"stg_order_reviews\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:37.022643Z", "completed_at": "2026-03-04T10:15:37.027596Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:37.030063Z", "completed_at": "2026-03-04T10:15:37.099381Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.07965993881225586, "adapter_response": {"_message": "CREATE VIEW", "code": "CREATE VIEW", "rows_affected": -1}, "message": "CREATE VIEW", "failures": null, "unique_id": "model.dbt_ecommerce.stg_sellers", "compiled": true, "compiled_code": "SELECT\n    seller_id,\n    seller_zip_code_prefix AS zip_code,\n    seller_city AS city,\n    seller_state AS state\nFROM \"analytics_warehouse\".\"public\".\"raw_sellers\"", "relation_name": "\"analytics_warehouse\".\"public\".\"stg_sellers\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:37.103278Z", "completed_at": "2026-03-04T10:15:37.105637Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:37.106076Z", "completed_at": "2026-03-04T10:15:37.261289Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.15928316116333008, "adapter_response": {"_message": "SELECT 32951", "code": "SELECT", "rows_affected": 32951}, "message": "SELECT 32951", "failures": null, "unique_id": "model.dbt_ecommerce.dim_products", "compiled": true, "compiled_code": "\n\nSELECT\n    p.product_id,\n    COALESCE(t.product_category_name_english, p.product_category_name, 'unknown') AS category_name,\n    p.product_weight_g,\n    p.product_length_cm,\n    p.product_height_cm,\n    p.product_width_cm\nFROM \"analytics_warehouse\".\"public\".\"stg_products\" p\nLEFT JOIN \"analytics_warehouse\".\"public\".\"stg_category_translations\" t\n    ON p.product_category_name = t.product_category_name", "relation_name": "\"analytics_warehouse\".\"public\".\"dim_products\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:37.037964Z", "completed_at": "2026-03-04T10:15:37.044420Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:37.060684Z", "completed_at": "2026-03-04T10:15:37.392687Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.36020803451538086, "adapter_response": {"_message": "INSERT 0 0", "code": "INSERT", "rows_affected": 0}, "message": "INSERT 0 0", "failures": null, "unique_id": "model.dbt_ecommerce.fact_sales", "compiled": true, "compiled_code": "\n\nWITH orders AS (\n    SELECT * FROM \"analytics_warehouse\".\"public\".\"stg_orders\"\n\n    -- THE TRUE INCREMENTAL LOGIC\n    -- This now correctly pulls ANY order that was modified recently, \n    -- regardless of when it was originally purchased!\n    \n        WHERE updated_at > (SELECT MAX(updated_at) FROM \"analytics_warehouse\".\"public\".\"fact_sales\")\n    \n),\nitems AS (\n    SELECT * FROM \"analytics_warehouse\".\"public\".\"stg_order_items\"\n)\n\nSELECT\n    i.order_id,\n    i.order_item_id,\n    o.customer_id,\n    i.product_id,\n    i.seller_id,\n    o.purchase_ts,\n    o.delivered_ts,\n    o.updated_at, -- Tracking the high-water mark\n    i.price,\n    i.freight_value,\n    i.total_item_value\nFROM items i\nJOIN orders o ON i.order_id = o.order_id", "relation_name": "\"analytics_warehouse\".\"public\".\"fact_sales\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:37.395474Z", "completed_at": "2026-03-04T10:15:37.397573Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:37.397963Z", "completed_at": "2026-03-04T10:15:37.479847Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.0856618881225586, "adapter_response": {"_message": "SELECT 3095", "code": "SELECT", "rows_affected": 3095}, "message": "SELECT 3095", "failures": null, "unique_id": "model.dbt_ecommerce.dim_sellers", "compiled": true, "compiled_code": "\n\nSELECT DISTINCT\n    seller_id,\n    zip_code,\n    city,\n    state\nFROM \"analytics_warehouse\".\"public\".\"stg_sellers\"", "relation_name": "\"analytics_warehouse\".\"public\".\"dim_sellers\""}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-03-04T10:15:37.034114Z", "completed_at": "2026-03-04T10:15:37.043176Z"}, {"name": "execute", "started_at": "2026-03-04T10:15:37.044664Z", "completed_at": "2026-03-04T10:15:37.682790Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.6551079750061035, "adapter_response": {"_message": "SELECT 99441", "code": "SELECT", "rows_affe