 (\n    SELECT * FROM \"analytics_warehouse\".\"public\".\"stg_orders\"\n),\nreviews AS (\n    SELECT * FROM \"analytics_warehouse\".\"public\".\"stg_order_reviews\"\n)\n\nSELECT\n    r.review_id,\n    r.order_id,\n    o.customer_id,\n    r.review_score,\n    r.review_creation_ts,\n    r.review_answer_ts\nFROM reviews r\nJOIN orders o ON r.order_id = o.order_id", "relation_name": "\"analytics_warehouse\".\"public\".\"fact_reviews\""}], "elapsed_time": 1.1703379154205322, "args": {"quiet": false, "log_path": "/Users/rtmagar/ecommerce_elt_project/dbt_ecommerce/logs", "log_level_file": "debug", "print": true, "indirect_selection": "eager", "vars": {}, "populate_cache": true, "select": [], "profiles_dir": "/Users/rtmagar/.dbt", "log_file_max_bytes": 10485760, "warn_error_options": {"include": [], "exclude": []}, "cache_selected_only": false, "static_parser": true, "partial_parse_file_diff": true, "strict_mode": false, "project_dir": "/Users/rtmagar/ecommerce_elt_project/dbt_ecommerce", "use_colors": true, "log_format": "default", "log_level": "info", "invocation_command": "dbt run", "introspect": true, "log_format_file": "debug", "send_anonymous_usage_stats": true, "favor_state": false, "enable_legacy_logger": false, "use_colors_file": true, "show_resource_report": false, "version_check": true, "write_json": true, "defer": false, "printer_width": 80, "macro_debugging": false, "which": "run", "exclude": [], "partial_parse": true}}