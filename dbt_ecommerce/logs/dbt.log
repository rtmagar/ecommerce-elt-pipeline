[0m05:34:51.788454 [debug] [Thread-1 (]: On model.dbt_ecommerce.fact_sales: /* {"app": "dbt", "dbt_version": "1.7.0", "profile_name": "dbt_ecommerce", "target_name": "dev", "node_id": "model.dbt_ecommerce.fact_sales"} */

    
  
    

  create temporary table "fact_sales__dbt_tmp053451771948"
  
  
    as
  
  (
    

WITH orders AS (
    SELECT * FROM "analytics_warehouse"."public"."stg_orders"
    WHERE order_status = 'delivered'

    -- THIS IS THE INCREMENTAL MAGIC
    
        -- Only process orders where the purchase timestamp is greater than the maximum timestamp currently in the target table
        AND purchase_ts > (SELECT MAX(purchase_ts) FROM "analytics_warehouse"."public"."fact_sales")
    
),
items AS (
    SELECT * FROM "analytics_warehouse"."public"."stg_order_items"
)

SELECT
    i.order_id,
    i.order_item_id,
    o.customer_id,
    i.product_id,
    i.seller_id,
    o.purchase_ts,
    o.delivered_ts,
    i.price,
    i.freight_value,
    i.total_item_value
FROM items i
JOIN orders o ON i.order_id = o.order_id
  );
  
  
